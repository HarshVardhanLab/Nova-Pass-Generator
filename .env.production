# Pass Generator Production Secrets
# ----------------------------------
# Place this file in the root of your project on EC2 as `.env`

# JWT Auth Secret (Generate a strong random string like `openssl rand -hex 32`)
SECRET_KEY=enter_secure_random_string_here_for_production

# Optional: Override the fallback QR decryption password globally
QR_ENCRYPTION_PASSWORD=hackgear2.0
